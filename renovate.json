{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "kubernetes": {
    "fileMatch": ["(^|/)operator/.+\\.ya?ml$", "(^|/)platform/.+\\.ya?ml$"]
  },
  "packageRules": [
    {
      "description": "Require separate review for Argo CD control-plane upgrades",
      "matchPackageNames": ["quay.io/argoprojlabs/argocd-operator"],
      "automerge": false,
      "labels": ["argocd-upgrade", "requires-e2e"]
    }
  ]
}

